################
# Applications #
################

# Rofi
alt + a
	xkb-switch -s us && rofi -show drun

# Google Chrome with WireGuard VPN
alt + b
	google-chrome-stable

# Discord with WireGuard VPN
alt + d
    MESA_LOADER_DRIVER_OVERRIDE=radeon discord

# Kitty terminal
alt + t
	xkb-switch -s us && kitty

# Calculator
alt + c
    gnome-calculator

# Messenger
alt + e
    Telegram

# Obsidian
alt + o
	obsidian

# UniversalPause (https://github.com/Evilur/Universal-Pause)
alt + F10
	universal-pause --run

# Make screenshot
~Print
	flameshot gui

#########
# Audio #
#########

# Raise the volume
XF86AudioRaiseVolume
	volumectl -d -M 0 up 10

# Lower the volume
XF86AudioLowerVolume
	volumectl -d -M 0 down 10

# Mute/unmute the audio
XF86AudioMute
    volumectl -d -M 0 toggle-mute

##############
# Brightness #
##############

# Raise the brightness
XF86MonBrightnessUp
	lightctl -d -M 0 up 10

# Lower the brightness
XF86MonBrightnessDown
	lightctl -d -M 0 down 10

########
# Misc #
########

# Hide/show the cursor
alt + x
    pointer-lock

# Quit the BSPWM
super + l
    bspc quit

# Disable picom frame limit
super + KP_Multiply
    pkill conky; pkill picom

# Reload configs
super + KP_Add
	pkill -USR1 -x sxhkd; bspc wm -r

# Turn off monitors
super + KP_Enter
	sleep 1; xset dpms force off

###########
# Windows #
###########

# Close the application (Blibk with red if can't close)
alt + {_,shift + }q
	bspc node --{close,kill} || bspc-blink RED

# Show desktop
super + d
    show-desktop

# Focus the window
alt + {h,l}
	bspc node --focus {prev,next}.local.window

# Move the window
alt + shift + {h,l}
    bspc node --swap {prev,next}.local.window

# Resize the window
alt + ctrl + {h,j,k,l}
    bspc-resize-window {right left -100 0,bottom top 0 100,\
                        bottom top 0 -100,right left 100 0}

# Set window status
super + {t,shift + t,f,shift + f}
	bspc node --state {tiled,pseudo_tiled,floating,fullscreen}

# Set window flag (Blink with green if all is OK)
super + {m,s,l,p}
	bspc node --flag {marked,sticky,locked,private} && bspc-blink GREEN

############
# Desktops #
############

# Monocle mode
alt + m
	bspc desktop -l next

# Focus to the last desktop
alt + space
	bspc desktop --focus last.local

# Focus to the prev/next desktop
alt + {j,k}
	bspc desktop --focus {prev,next}.local

# Focus to the {0-9} desktop
alt + {0-9}
    bspc desktop --focus {0-9}

# Move the focused window to the last desktop
alt + shift + space
    bspc node --to-desktop last.local --follow

# Move the focused window to the prev/next desktop
alt + shift + {j,k}
	bspc node --to-desktop {prev,next}.local --follow

# Move the focused window to the {0-9} desktop
alt + shift + {0-9}
    bspc node --to-desktop {0-9} --follow

############
# Monitors #
############

# Focus to the other monitor
alt + i
	bspc monitor --focus next

alt + shift + i
    bspc node --to-monitor next --follow
