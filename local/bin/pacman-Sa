#!/usr/bin/env sh
set -e

# Set sudo command
readonly SUDO=doas

# Remove unneccesary dependencies
paru -cc --noconfirm

# Full system upgrade
paru -Syyu --noconfirm

# Backup initramfs
$SUDO mv -vf /boot/initramfs* /tmp

# Try to regenerate the boot image
$SUDO dracut --force --regenerate-all --verbose || {
    # If the regenerating has been canceled, restore the backup
    mv -v /tmp/initramfs* /boot

    # Exit with the error code
    exit 1
}

# If all is OK, set the right name
$SUDO mv -v /boot/initramfs* /boot/initramfs-linux.img

# Exit with the success code
exit 0
