#!/usr/bin/env sh
set -e

# Set sudo command
readonly SUDO=doas

# Remove unneccesary dependencies
paru -cc --noconfirm

# Full system upgrade
paru -Syyu --noconfirm

# Backup initramfs
$SUDO mv -v /boot/initramfs* /tmp 2>/dev/null || true

# Try to regenerate the boot image
$SUDO mkinitcpio -g /boot/initramfs-linux.img || {
    # If the regenerating has been canceled, restore the backup
    mv -v /tmp/initramfs* /boot

    # Exit with the error code
    exit 1
}

# Exit with the success code
exit 0
