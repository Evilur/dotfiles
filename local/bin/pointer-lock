#!/usr/bin/env sh

# File to save the pointer state
readonly LOCK_FILE=/tmp/$USER.pointer.lock

# If cursor is NOT locked
if ! [[ -f $LOCK_FILE ]]; then
    # Move the cursor to the screen corner
    xdotool mousemove 0 9999

    # Disable xinput device
    for id in $(xinput |\
            grep -w slave |\
            grep -w pointer |\
            grep -Eow 'id=[0-9]+' |\
            grep -Eo '[0-9]+'); do
        xinput disable $id
    done

    # Create .lock file
    touch $LOCK_FILE
# If cursor is already locked
else
    # Get the primary monitor resolution and position
    readonly PRIMARY_DATA=$(
        xrandr --query |
            grep primary |
            grep -oE '[0-9]+x[0-9]+\+[0-9]+\+[0-9]+'
        )
    IFS='x+' read -r width height x y <<< "$PRIMARY_DATA"

    # Move the cursor to the center of the screen
    xdotool mousemove $(( x + width / 2 )) $(( y + height / 2 ))

        # Disable xinput device
        for id in $(xinput |\
            grep -w slave |\
            grep -w floating |\
            grep -Eow 'id=[0-9]+' |\
            grep -Eo '[0-9]+'); do
        xinput enable $id
    done

    # Remove .lock file
    rm $LOCK_FILE
fi
